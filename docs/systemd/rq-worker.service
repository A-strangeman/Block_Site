[Unit]
Description=RQ Worker for FocusGuard
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/srv/focusguard
Environment=REDIS_URL=redis://localhost:6379/0
ExecStart=/usr/local/bin/rq worker default -u $REDIS_URL
Restart=always

[Install]
WantedBy=multi-user.target
